# Content Studio — Local Configuration
# Copy this file to .env and set your credential directory.
# .env is gitignored and will not be committed.

# Directory containing Google OAuth client_secret*.json, token.pickle, and API keys.
# If not set, defaults to ~/.content-studio/
# CSTUDIO_CREDENTIALS_DIR=/Users/you/path/to/credentials

# Image generation models (optional — defaults shown)
# CSTUDIO_IMAGE_MODEL_STANDARD=gemini-2.5-flash-image
# CSTUDIO_IMAGE_MODEL_HIGH=gemini-3-pro-image-preview
